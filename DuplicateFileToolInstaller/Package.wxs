<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="Duplicate File Tool"
    Manufacturer="Dennis Reshetnyak"
    Version="2.1.0"
    UpgradeCode="F5EAE4DE-2E5B-4E48-A282-1208C1345D14"
    InstallerVersion="405"
    Scope="perMachine">

    <SummaryInformation
      Description="Duplicate File Tool"
      Manufacturer="Dennis Reshetnyak" />

    <!-- ============================================================
         Upgrade handling.

         The previous releases installed an x86-style layout into
         "Program Files (x86)\DuplicateFileTool" (exe, exe.config and the
         en/es/ru satellite resource DLLs). This version installs the new
         self-contained single-file exe into the proper 64-bit location
         "Program Files\DuplicateFileTool" (ProgramFiles64Folder).

         Because the install path changes, this one upgrade is a clean
         relocation that wipes the old install entirely:
           * The major upgrade (RemoveExistingProducts, same UpgradeCode)
             uninstalls the entire old product from the (x86) folder.
           * MSI would normally PRESERVE the runtime-modified, unversioned
             old config; we do NOT want that here, so the
             CMP_CleanupOldX86Install component deletes whatever remains in
             the old (x86) folder (the leftover config) and removes the now
             empty folder. Result: the old install is gone completely,
             config included, and everything is fresh in the new path.

         FUTURE upgrades (this x64 product -> a newer x64 build) keep the
         SAME path "Program Files\DuplicateFileTool" and the SAME
         UpgradeCode. The config is unversioned, written by the app after
         install, and is NOT shipped as a component, so MSI preserves it in
         place across those upgrades automatically. To keep that working,
         a future version must NOT change the install path, must NOT add a
         config component, and must NOT change the UpgradeCode.
         ============================================================ -->
    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <!-- Media / branding -->
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="icon.ico" SourceFile="DuplicateFileTool.ico" />
    <Property Id="ARPPRODUCTICON" Value="icon.ico" />

    <!-- UI -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="gpl-3.0.rtf" />
    <WixVariable Id="WixUIDialogBmp" Value="Installer.bmp" />

    <!-- New install location: the proper 64-bit Program Files folder.
         ProgramFiles64Folder = "C:\Program Files"; ProgramFilesFolder is the
         32-bit "C:\Program Files (x86)" that the old releases used. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DuplicateFileTool" />
    </StandardDirectory>
    <!-- Old x86 install location, cleaned up on this upgrade. -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="OLDINSTALLFOLDER" Name="DuplicateFileTool" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainApp" Title="Duplicate File Tool Application" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <ComponentGroup Id="ProductComponents">

      <!-- The single, self-contained x64 executable, installed into the
           64-bit Program Files folder. -->
      <Component Id="CMP_DuplicateFileTool_exe"
                 Directory="INSTALLFOLDER"
                 Guid="487D0093-1337-439E-AD96-B531F08F1125">
        <File Id="FILE_DuplicateFileTool_exe"
              Source="..\DuplicateFileTool\bin\Publish\DuplicateFileTool.exe"
              KeyPath="yes" />
      </Component>

      <!-- One-time cleanup of the previous x86 install. The major upgrade
           removes the old product's tracked files, but MSI would otherwise
           preserve the runtime-modified config; this deletes that leftover
           config and removes the now-empty old (x86) folder so nothing is
           left behind there. On future upgrades the old folder is already
           gone, so this is a harmless no-op. -->
      <Component Id="CMP_CleanupOldX86Install"
                 Directory="OLDINSTALLFOLDER"
                 Bitness="always32"
                 Guid="2D6E7F1B-9C84-4B0E-9E0A-7F2C1A4D8E55">
        <RemoveFile Id="RmOldX86Files" Name="*.*" On="install" />
        <RemoveFolder Id="RmOldX86Folder" On="install" />
        <RegistryValue Root="HKLM"
                       Key="Software\DuplicateFileTool"
                       Name="LegacyX86Cleanup"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- Start menu shortcut -->
      <Component Id="CMP_MainAppShortcutMenu"
                 Directory="ProgramMenuFolder"
                 Guid="A9769067-55A3-438D-9C4A-80AA94369CEA">
        <Shortcut Id="DuplicateFileToolShortcutMenu"
                  Name="Duplicate File Tool"
                  Description="Duplicate File Tool Application"
                  Target="[#FILE_DuplicateFileTool_exe]"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\DuplicateFileTool"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- Desktop shortcut -->
      <Component Id="CMP_MainAppShortcutDesktop"
                 Directory="DesktopFolder"
                 Guid="3A7DE1E6-76B8-42AA-865D-81C2E3066012">
        <Shortcut Id="DuplicateFileToolShortcutDesktop"
                  Name="Duplicate File Tool"
                  Description="Duplicate File Tool Application"
                  Target="[#FILE_DuplicateFileTool_exe]"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveDesktopFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\DuplicateFileTool"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

    </ComponentGroup>

  </Package>
</Wix>
